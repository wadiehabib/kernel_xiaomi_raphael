&mdss_mdp {
	dsi_k9b_42_02_0a_dsc_cmd: qcom,mdss_dsi_k9b_42_02_0a_dsc_cmd {
		qcom,mdss-dsi-panel-name = "xiaomi 42 02 0a cmd mode dsc dsi panel";
		qcom,mdss-dsi-panel-type = "dsi_cmd_mode";
