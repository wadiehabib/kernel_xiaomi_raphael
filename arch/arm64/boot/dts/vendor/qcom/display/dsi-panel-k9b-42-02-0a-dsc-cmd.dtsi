					/* FCON = 1 (90hz) */
					39 00 00 00 00 00 09 BA 01 E9 00 10 00 30 00 01
					/* FCON = 2 (60hz) */
					15 00 00 00 00 00 02 6F 08
					39 00 00 00 00 00 09 BA 01 E9 00 10 04 D0 00 01	// PWM 60&90Hz
